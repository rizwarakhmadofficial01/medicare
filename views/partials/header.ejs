<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MediCare</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="navbar">
    <a href="/" class="brand">🩺 Medi<span class="dot">Care</span></a>
    <nav>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'admin') { %>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/doctors">Kelola Dokter</a>
          <a href="/admin/appointments">Kelola Janji Temu</a>
          <a href="/admin/users">Pasien</a>
        <% } else { %>
          <a href="/user/dashboard">Dashboard</a>
          <a href="/user/doctors">Dokter</a>
          <a href="/user/appointments">Janji Temu Saya</a>
        <% } %>
        <span class="user-badge"><%= currentUser.name %> · <%= currentUser.role === 'admin' ? 'admin' : 'pasien' %></span>
        <form action="/logout" method="POST">
          <button class="btn-logout" type="submit">Logout</button>
        </form>
      <% } %>
    </nav>
  </div>
  <div class="container">
    <% if (successMsg && successMsg.length) { %>
      <div class="alert alert-success"><%= successMsg[0] %></div>
    <% } %>
    <% if (errorMsg && errorMsg.length) { %>
      <div class="alert alert-error"><%= errorMsg[0] %></div>
    <% } %>
