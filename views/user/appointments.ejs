<%- include('../partials/header') %>

<div class="page-title">Riwayat Janji Temu Saya</div>
<div class="page-subtitle">Semua janji temu yang pernah kamu buat.</div>

<% if (appointments.length === 0) { %>
  <div class="card empty-state">Belum ada riwayat janji temu. <a href="/user/doctors" style="color:#0d9488;font-weight:600;">Buat sekarang →</a></div>
<% } else { %>
  <table>
    <thead><tr><th>Dokter</th><th>Tanggal</th><th>Jam</th><th>Total</th><th>Status</th><th>Aksi</th></tr></thead>
    <tbody>
      <% appointments.forEach(a => { %>
        <tr>
          <td><%= a.doctor_name %> <small style="color:#94a3b8;">(<%= a.category %>)</small></td>
          <td><%= a.booking_date %></td>
          <td><%= a.start_time %> - <%= a.end_time %></td>
          <td>Rp <%= a.total_price.toLocaleString('id-ID') %></td>
          <td><span class="badge badge-<%= a.status %>"><%= a.status %></span></td>
          <td>
            <% if (['pending','confirmed'].includes(a.status)) { %>
              <form action="/user/appointments/<%= a.id %>/cancel?_method=PUT" method="POST" onsubmit="return confirm('Batalkan janji temu ini?');">
                <button class="btn btn-danger btn-sm" type="submit">Batalkan</button>
              </form>
            <% } else { %>
              <span style="color:#94a3b8; font-size:0.8rem;">-</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
